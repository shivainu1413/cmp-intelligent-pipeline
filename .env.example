# Copy this file to .env and fill in your actual values.
# .env is in .gitignore and will NOT be pushed to Git.

# MongoDB Atlas
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# Gemini API Key
GEMINI_API_KEY=AIza...

# Slack Webhooks
SLACK_ANOMALY_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
SLACK_MISMATCH_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# PostgreSQL (internal container connection, usually no need to change)
POSTGRES_CONN_STR=postgresql+psycopg2://airflow:airflow@postgres/airflow
